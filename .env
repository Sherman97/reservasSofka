# ============================================================
# Reservas SK — Variables de Entorno
# Copiar como .env y ajustar los valores para tu entorno
# ============================================================

# ── Base de datos (MariaDB) ──────────────────────────────────
DB_ROOT_PASSWORD=root
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=123456

# ── JWT ──────────────────────────────────────────────────────
# IMPORTANTE: cambiar en produccion por un secreto seguro (min 32 caracteres / 256 bits)
JWT_SECRET=R3s3rv4sSK_S3cur3_JWT_S3cr3t_K3y!

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_ENABLED=true
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=reservas.events
RABBITMQ_QUEUE=notifications.events.q
RABBITMQ_ROUTING_KEYS=auth.user.created,bookings.reservation.created,bookings.reservation.cancelled,inventory.equipment.created,inventory.equipment.updated,inventory.equipment.deleted,locations.city.created,locations.city.updated,locations.city.deleted,locations.space.created,locations.space.updated,locations.space.deleted

# ── WebSocket ────────────────────────────────────────────────
WEBSOCKET_ALLOWED_ORIGINS=*

# ── Frontend (build-time — Vite embebe estos valores) ────────
# Produccion (nginx reverse proxy en puerto 8080):
VITE_API_URL=http://localhost:8080
VITE_BOOKINGS_URL=http://localhost:8080
VITE_BOOKINGS_WS_URL=ws://localhost:8080/bookings/ws

# Desarrollo (acceso directo al gateway):
# VITE_API_URL=http://localhost:3000
# VITE_BOOKINGS_URL=http://localhost:3000
# VITE_BOOKINGS_WS_URL=ws://localhost:3000/bookings/ws

# ── Puerto del frontend ─────────────────────────────────────
# Produccion: 8080 | Desarrollo: 5173
FRONTEND_PORT=8080
